# ============================================================
# BizVaani Backend — Environment Variables
# Copy to .env and fill in your API keys
# ============================================================

# Database (SQLite for dev, PostgreSQL for prod)
DATABASE_URL=sqlite+aiosqlite:///./bizvaani.db
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/bizvaani

# JWT Auth
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRY_DAYS=7

# Sarvam AI (STT + TTS)
SARVAM_API_KEY=your-sarvam-api-key

# Groq (LLM)
GROQ_API_KEY=your-groq-api-key

# Tavily (Web Search for competitor intel)
TAVILY_API_KEY=your-tavily-api-key

# Agmarknet (Mandi Prices)
AGMARKNET_API_KEY=your-agmarknet-api-key

# Server
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:3000,https://bizvaani.vercel.app
